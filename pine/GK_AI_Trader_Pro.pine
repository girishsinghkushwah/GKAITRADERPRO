//@version=6

//=============================================================================
// GK AI TRADER PRO
// Institutional Decision Engine
// Version : 0.1.0
// Author  : Girish Kushwah + ChatGPT
//=============================================================================

indicator(
     title = "GK AI Trader Pro",
     shorttitle = "GK AI",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500
)

//=============================================================================
// PROJECT INFORMATION
//=============================================================================

var string PROJECT_NAME    = "GK AI Trader Pro"
var string VERSION         = "0.1.0"
var string BUILD_DATE      = "2026-07-07"

var string DEVELOPER       = "Girish Kushwah"
var string ENGINE          = "Institutional Decision Engine"

var bool INITIALIZED = true
plot(close, title="Foundation")
//=============================================================================
// INPUT SETTINGS
//=============================================================================

// General
groupGeneral = "⚙️ General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
showSignals   = input.bool(true, "Show Buy/Sell Signals", group = groupGeneral)
enableAlerts  = input.bool(true, "Enable Alerts", group = groupGeneral)

// Market
groupMarket = "📈 Market"

marketType = input.string(
     "NIFTY",
     "Market",
     options = ["NIFTY", "SENSEX", "BANKNIFTY"],
     group = groupMarket
)

// Trading Style
groupStyle = "🎯 Trading Style"

tradingStyle = input.string(
     "Intraday",
     "Style",
     options = ["Scalping", "Intraday", "Swing"],
     group = groupStyle
)
//=============================================================================
// THEME ENGINE
//=============================================================================

groupTheme = "🎨 Theme"

theme = input.string(
     "Institutional Dark",
     "Theme",
     options = [
         "Institutional Dark",
         "Light",
         "Classic"
     ],
     group = groupTheme
)

// Color Palette
bullColor    = color.lime
bearColor    = color.red
neutralColor = color.orange

dashboardBg  = color.rgb(25, 25, 30)
dashboardTxt = color.white

buyColor     = color.lime
sellColor    = color.red
warningColor = color.yellow
//=============================================================================
// UTILITY ENGINE
//=============================================================================

// Candle Information
isBullish() =>
    close > open

isBearish() =>
    close < open

candleBody() =>
    math.abs(close - open)

upperWick() =>
    high - math.max(open, close)

lowerWick() =>
    math.min(open, close) - low

// Trend Helpers
isAboveVWAP(vwapValue) =>
    close > vwapValue

isBelowVWAP(vwapValue) =>
    close < vwapValue

// Price Helpers
priceChange() =>
    close - close[1]

priceChangePercent() =>
    ((close - close[1]) / close[1]) * 100
    //=============================================================================
// DASHBOARD FOUNDATION
//=============================================================================

groupDashboard = "📊 Dashboard"

dashboardPosition = input.string(
     "Top Right",
     "Position",
     options = [
          "Top Right",
          "Top Left",
          "Bottom Right",
          "Bottom Left"
     ],
     group = groupDashboard
)

dashboardSize = input.string(
     "Normal",
     "Size",
     options = [
          "Small",
          "Normal",
          "Large"
     ],
     group = groupDashboard
)

showVersion = input.bool(
     true,
     "Show Version",
     group = groupDashboard
)
//=============================================================================
// EMA ENGINE
//=============================================================================

groupEMA = "📈 EMA Engine"

enableEMA = input.bool(true, "Enable EMA Engine", group = groupEMA)

emaFastLength = input.int(8, "Fast EMA", minval = 1, group = groupEMA)
emaSlowLength = input.int(14, "Slow EMA", minval = 1, group = groupEMA)

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)

// Trend State
trendBullish = emaFast > emaSlow
trendBearish = emaFast < emaSlow
trendNeutral = emaFast == emaSlow

// EMA Distance
emaDistance = math.abs(emaFast - emaSlow)

// EMA Slope
emaFastSlope = emaFast - emaFast[1]
emaSlowSlope = emaSlow - emaSlow[1]

// Plots
plot(enableEMA ? emaFast : na,
     title = "EMA Fast",
     color = bullColor,
     linewidth = 2)

plot(enableEMA ? emaSlow : na,
     title = "EMA Slow",
     color = bearColor,
     linewidth = 2)
     //=============================================================================
// VWAP ENGINE
//=============================================================================

groupVWAP = "📊 VWAP Engine"

enableVWAP = input.bool(true, "Enable VWAP Engine", group = groupVWAP)
showVWAP   = input.bool(true, "Show VWAP", group = groupVWAP)

// VWAP
vwapValue = ta.vwap(close)

// Market State
priceAboveVWAP = close > vwapValue
priceBelowVWAP = close < vwapValue
priceOnVWAP    = close == vwapValue

// Distance
vwapDistance = math.abs(close - vwapValue)

// Plot
plot(
     enableVWAP and showVWAP ? vwapValue : na,
     title = "VWAP",
     color = color.aqua,
     linewidth = 2
)
//=============================================================================
// VOLUME ENGINE
//=============================================================================

groupVolume = "📊 Volume Engine"

enableVolume = input.bool(true, "Enable Volume Engine", group = groupVolume)

volumeLength = input.int(
     20,
     "Average Volume Length",
     minval = 1,
     group = groupVolume
)

rvolThreshold = input.float(
     1.5,
     "RVOL Threshold",
     step = 0.1,
     group = groupVolume
)

// Average Volume
avgVolume = ta.sma(volume, volumeLength)

// Relative Volume
rvol = avgVolume > 0 ? volume / avgVolume : 0

// Volume Conditions
highVolume = volume > avgVolume
volumeSpike = rvol >= rvolThreshold

// Plot Average Volume (Hidden)
plot(
     enableVolume ? avgVolume : na,
     title = "Average Volume",
     display = display.none
)
//=============================================================================
// RSI ENGINE
//=============================================================================

groupRSI = "📈 RSI Engine"

enableRSI = input.bool(true, "Enable RSI Engine", group = groupRSI)

rsiLength = input.int(
    14,
    "RSI Length",
    minval = 2,
    group = groupRSI
)

rsiOB = input.int(
    70,
    "Overbought",
    minval = 50,
    maxval = 100,
    group = groupRSI
)

rsiOS = input.int(
    30,
    "Oversold",
    minval = 0,
    maxval = 50,
    group = groupRSI
)

// RSI Calculation
rsiValue = ta.rsi(close, rsiLength)

// Momentum States
rsiStrongBull = rsiValue >= 70
rsiBull       = rsiValue > 55 and rsiValue < 70
rsiNeutral    = rsiValue >= 45 and rsiValue <= 55
rsiBear       = rsiValue < 45 and rsiValue > 30
rsiStrongBear = rsiValue <= 30

// Hidden Plot (Future AI Use)
plot(
    enableRSI ? rsiValue : na,
    title = "RSI",
    display = display.none
)
//=============================================================================
// MACD ENGINE
//=============================================================================

groupMACD = "📉 MACD Engine"

enableMACD = input.bool(true, "Enable MACD Engine", group = groupMACD)

macdFast = input.int(12, "Fast Length", group = groupMACD)
macdSlow = input.int(26, "Slow Length", group = groupMACD)
macdSignal = input.int(9, "Signal Length", group = groupMACD)

// Calculation
[macdLine, signalLine, histogram] = ta.macd(close, macdFast, macdSlow, macdSignal)

// States
macdBullish = macdLine > signalLine
macdBearish = macdLine < signalLine

macdStrongBull = histogram > 0 and histogram > histogram[1]
macdStrongBear = histogram < 0 and histogram < histogram[1]

// Hidden Plot
plot(
    enableMACD ? macdLine : na,
    title = "MACD",
    display = display.none
)
//=============================================================================
// ADX ENGINE
//=============================================================================

groupADX = "📊 ADX Engine"

enableADX = input.bool(true, "Enable ADX Engine", group = groupADX)

adxLength = input.int(
    14,
    "ADX Length",
    minval = 2,
    group = groupADX
)

adxStrongLevel = input.int(
    25,
    "Strong Trend Level",
    minval = 10,
    maxval = 50,
    group = groupADX
)

// ADX Calculation
[diplus, diminus, adxValue] = ta.dmi(adxLength, adxLength)

// Trend Strength
strongTrend = adxValue >= adxStrongLevel
weakTrend   = adxValue < adxStrongLevel

bullTrend = diplus > diminus
bearTrend = diminus > diplus

// Hidden Plot
plot(
    enableADX ? adxValue : na,
    title = "ADX",
    display = display.none
)
//=============================================================================
// ATR ENGINE
//=============================================================================

groupATR = "📏 ATR Engine"

enableATR = input.bool(true, "Enable ATR Engine", group = groupATR)

atrLength = input.int(
    14,
    "ATR Length",
    minval = 1,
    group = groupATR
)

atrMultiplier = input.float(
    2.0,
    "ATR Multiplier",
    minval = 0.5,
    step = 0.5,
    group = groupATR
)

// ATR Calculation
atrValue = ta.atr(atrLength)

// Volatility State
highVolatility = atrValue > ta.sma(atrValue, atrLength)
lowVolatility  = atrValue <= ta.sma(atrValue, atrLength)

// Suggested Stop Loss Distance
atrSL = atrValue * atrMultiplier

// Hidden Plot
plot(
    enableATR ? atrValue : na,
    title = "ATR",
    display = display.none
)
//=============================================================================
// AI SCORE ENGINE
//=============================================================================

groupAI = "🧠 AI Score"

showAIScore = input.bool(true, "Enable AI Score", group = groupAI)

//----------------------------------------------------
// Trend Score
//----------------------------------------------------

trendScore = 0

trendScore += trendBullish ? 20 : 0
trendScore += priceAboveVWAP ? 20 : 0

//----------------------------------------------------
// Momentum Score
//----------------------------------------------------

momentumScore = 0

momentumScore += rsiBull or rsiStrongBull ? 15 : 0
momentumScore += macdBullish ? 15 : 0

//----------------------------------------------------
// Strength Score
//----------------------------------------------------

strengthScore = 0

strengthScore += strongTrend ? 10 : 0
strengthScore += volumeSpike ? 10 : 0

//----------------------------------------------------
// Risk Score
//----------------------------------------------------

riskScore = 0

riskScore += lowVolatility ? 10 : 0

//----------------------------------------------------
// Final Score
//----------------------------------------------------

aiScore = trendScore + momentumScore + strengthScore + riskScore

confidence = aiScore

//=============================================================================
// CORE STATE ENGINE
//=============================================================================

groupCore = "🧠 Core State Engine"

enableCore = input.bool(
    true,
    "Enable Core State Engine",
    group = groupCore
)

//======================================================
// STATE VALUES
//======================================================

// Trend
trendState = trendBullish ? 1 : trendBearish ? -1 : 0

// Momentum
momentumState =
     (rsiBull or rsiStrongBull) and macdBullish ? 1 :
     (rsiBear or rsiStrongBear) and macdBearish ? -1 : 0

// Strength
strengthState = strongTrend ? 1 : 0

// Volume
volumeState = volumeSpike ? 1 : 0

// Risk
riskState = lowVolatility ? 1 : 0

//======================================================
// MASTER STATE
//======================================================

marketState =
     trendState +
     momentumState +
     strengthState +
     volumeState +
     riskState
     //=============================================================================
// DECISION ENGINE
//=============================================================================

groupDecision = "🎯 Decision Engine"

enableDecision = input.bool(
    true,
    "Enable Decision Engine",
    group = groupDecision
)

// Decision Score
buyCall =
     aiScore >= 80 and
     trendState == 1 and
     momentumState == 1

buyPut =
     aiScore >= 80 and
     trendState == -1 and
     momentumState == -1

waitTrade =
     aiScore >= 60 and aiScore < 80

noTrade =
     aiScore < 60

// Decision Text
decision =
     buyCall ? "BUY CALL" :
     buyPut ? "BUY PUT" :
     waitTrade ? "WAIT" :
     "NO TRADE"
     //=============================================================================
// AI DASHBOARD
//=============================================================================

groupDashboardUI = "🖥️ AI Dashboard"

showAIDashboard = input.bool(true, "Show AI Dashboard", group = groupDashboardUI)

var table aiDashboard = table.new(position.top_right, 2, 6, border_width = 1)

if barstate.islast and showAIDashboard
    table.cell(aiDashboard, 0, 0, "GK AI Trader", bgcolor=color.blue, text_color=color.white)
    table.cell(aiDashboard, 1, 0, "v0.1.16", bgcolor=color.blue, text_color=color.white)

    table.cell(aiDashboard, 0, 1, "AI Score")
    table.cell(aiDashboard, 1, 1, str.tostring(aiScore))

    table.cell(aiDashboard, 0, 2, "Decision")
    table.cell(aiDashboard, 1, 2, decision)

    table.cell(aiDashboard, 0, 3, "Trend")
    table.cell(aiDashboard, 1, 3, trendState == 1 ? "Bullish" : trendState == -1 ? "Bearish" : "Neutral")

    table.cell(aiDashboard, 0, 4, "Momentum")
    table.cell(aiDashboard, 1, 4, momentumState == 1 ? "Bullish" : momentumState == -1 ? "Bearish" : "Neutral")

    table.cell(aiDashboard, 0, 5, "Volume")
    table.cell(aiDashboard, 1, 5, volumeSpike ? "High" : "Normal")
    //=============================================================================
// ALERT ENGINE
//=============================================================================

groupAlerts = "🔔 Alert Engine"

enableAIAlerts = input.bool(true, "Enable Alerts", group = groupAlerts)

//----------------------------------------------------
// Alert Conditions
//----------------------------------------------------

buyCallAlert = enableAIAlerts and buyCall
buyPutAlert  = enableAIAlerts and buyPut
waitAlert    = enableAIAlerts and waitTrade

//----------------------------------------------------
// TradingView Alerts
//----------------------------------------------------

alertcondition(
    buyCallAlert,
    title = "BUY CALL",
    message = "GK AI Trader Pro : BUY CALL"
)

alertcondition(
    buyPutAlert,
    title = "BUY PUT",
    message = "GK AI Trader Pro : BUY PUT"
)

alertcondition(
    waitAlert,
    title = "WAIT",
    message = "GK AI Trader Pro : WAIT"
)
//=============================================================================
// TRADE MANAGEMENT ENGINE
//=============================================================================

groupTrade = "💼 Trade Management"

enableTradeManagement = input.bool(
    true,
    "Enable Trade Management",
    group = groupTrade
)

//----------------------------------------------------
// Entry
//----------------------------------------------------

entryPrice = close

//----------------------------------------------------
// Stop Loss
//----------------------------------------------------

longSL = low - atrValue
shortSL = high + atrValue

//----------------------------------------------------
// Risk Reward
//----------------------------------------------------

riskReward = input.float(
    2.0,
    "Risk Reward",
    step = 0.5,
    group = groupTrade
)

//----------------------------------------------------
// Targets
//----------------------------------------------------

longTarget = entryPrice + (entryPrice - longSL) * riskReward

shortTarget = entryPrice - (shortSL - entryPrice) * riskReward
//=============================================================================
// RISK ENGINE
//=============================================================================

groupRisk = "⚠️ Risk Engine"

enableRiskEngine = input.bool(
    true,
    "Enable Risk Engine",
    group = groupRisk
)

//----------------------------------------------------
// Maximum Risk (%)
//----------------------------------------------------

maxRiskPercent = input.float(
    1.0,
    "Maximum Risk %",
    step = 0.25,
    group = groupRisk
)

//----------------------------------------------------
// Risk Calculation
//----------------------------------------------------

tradeRisk = math.abs(entryPrice - longSL)

riskAllowed = tradeRisk > 0

riskStateEngine = enableRiskEngine and riskAllowed ? 1 : 0
//=============================================================================
// SESSION ENGINE
//=============================================================================

groupSession = "🕒 Session Engine"

enableSessionEngine = input.bool(
    true,
    "Enable Session Filter",
    group = groupSession
)

tradeSession = input.session(
    "0915-1530",
    "Trading Session",
    group = groupSession
)

sessionActive = not na(time(timeframe.period, tradeSession))

allowTrading = enableSessionEngine ? sessionActive : true
//=============================================================================
// INDIA VIX ENGINE
// MODULE 1.21
//=============================================================================

groupVIX = "📉 India VIX"

enableVIX = input.bool(true, "Enable India VIX", group = groupVIX)

vixSymbol = input.symbol("NSE:INDIAVIX", "India VIX Symbol", group = groupVIX)

vixValue = request.security(vixSymbol, timeframe.period, close)
vixPrevious = request.security(vixSymbol, timeframe.period, close[1])

vixRising = vixValue > vixPrevious
vixFalling = vixValue < vixPrevious

vixHigh = vixValue >= 20
vixMedium = vixValue >= 15 and vixValue < 20
vixLow = vixValue < 15
//=============================================================================
// INSTITUTIONAL DASHBOARD
// MODULE 2.1 - PART A
//=============================================================================

groupInstDash = "🏦 Institutional Dashboard"

showInstDash = input.bool(true, "Show Institutional Dashboard", group=groupInstDash)

instDashBg = input.color(color.new(color.black, 10), "Dashboard Background", group=groupInstDash)

instDashText = input.color(color.white, "Dashboard Text", group=groupInstDash)

var table instDashboard = table.new(position.top_right, 2, 25, border_width=1)
if barstate.islast and showInstDash
    table.clear(instDashboard, 0, 0)

    table.cell(instDashboard, 0, 0, "GK AI TRADER PRO", bgcolor=instDashBg, text_color=color.yellow)
    table.cell(instDashboard, 1, 0, "v0.2.1", bgcolor=instDashBg, text_color=color.aqua)
table.cell(instDashboard, 0, 1, "AI Score", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 1, str.tostring(aiScore), bgcolor=instDashBg, text_color=color.lime)

table.cell(instDashboard, 0, 2, "Decision", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 2, decision, bgcolor=instDashBg, text_color=color.yellow)

table.cell(instDashboard, 0, 3, "Trend", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 3, trendState == 1 ? "Bullish" : trendState == -1 ? "Bearish" : "Neutral", bgcolor=instDashBg, text_color=color.aqua)

table.cell(instDashboard, 0, 4, "Momentum", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 4, momentumState == 1 ? "Bullish" : momentumState == -1 ? "Bearish" : "Neutral", bgcolor=instDashBg, text_color=color.orange)

table.cell(instDashboard, 0, 5, "Session", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 5, allowTrading ? "ACTIVE" : "CLOSED", bgcolor=instDashBg, text_color=allowTrading ? color.lime : color.red)
//=============================================================================
// BOS ENGINE
// MODULE 2.2
//=============================================================================

groupBOS = "🏗️ BOS Engine"

enableBOS = input.bool(true, "Enable BOS", group=groupBOS)

bosSwingLength = input.int(5, "Swing Length", minval=2, group=groupBOS)

// Swing High / Low
swingHigh = ta.pivothigh(high, bosSwingLength, bosSwingLength)
swingLow  = ta.pivotlow(low, bosSwingLength, bosSwingLength)

// Last Confirmed Swing Levels
lastSwingHigh = ta.valuewhen(not na(swingHigh), swingHigh, 0)
lastSwingLow  = ta.valuewhen(not na(swingLow), swingLow, 0)

// BOS Conditions
bullishBOS = enableBOS and not na(lastSwingHigh) and close > lastSwingHigh
bearishBOS = enableBOS and not na(lastSwingLow) and close < lastSwingLow
//=============================================================================
// CHOCH ENGINE
// MODULE 2.3
//=============================================================================

groupCHOCH = "🔄 CHOCH Engine"

enableCHOCH = input.bool(true, "Enable CHOCH", group = groupCHOCH)

// CHOCH Conditions
bullishCHOCH = enableCHOCH and bearishBOS[1] and bullishBOS

bearishCHOCH = enableCHOCH and bullishBOS[1] and bearishBOS
//=============================================================================
// LIQUIDITY SWEEP ENGINE
// MODULE 2.4
//=============================================================================

groupLiquidity = "💧 Liquidity Sweep"

enableLiquidity = input.bool(true, "Enable Liquidity Sweep", group = groupLiquidity)

lookbackLiquidity = input.int(20, "Liquidity Lookback", minval = 5, group = groupLiquidity)

highestLiquidity = ta.highest(high, lookbackLiquidity)
lowestLiquidity = ta.lowest(low, lookbackLiquidity)

bullishLiquiditySweep = enableLiquidity and high > highestLiquidity[1] and close < highestLiquidity[1]

bearishLiquiditySweep = enableLiquidity and low < lowestLiquidity[1] and close > lowestLiquidity[1]
//=============================================================================
// ORDER BLOCK ENGINE
// MODULE 2.5
//=============================================================================

groupOB = "📦 Order Block"

enableOB = input.bool(true, "Enable Order Blocks", group = groupOB)

bullishOB = enableOB and close[1] < open[1] and bullishBOS

bearishOB = enableOB and close[1] > open[1] and bearishBOS

bullishOBHigh = high[1]
bullishOBLow = low[1]

bearishOBHigh = high[1]
bearishOBLow = low[1]
//=============================================================================
// FAIR VALUE GAP ENGINE
// MODULE 2.6
//=============================================================================

groupFVG = "🟨 Fair Value Gap"

enableFVG = input.bool(true, "Enable FVG", group = groupFVG)

// Bullish FVG
bullishFVG = enableFVG and low > high[2]

// Bearish FVG
bearishFVG = enableFVG and high < low[2]

// FVG Levels
bullishFVGTop = low
bullishFVGBottom = high[2]

bearishFVGTop = low[2]
bearishFVGBottom = high
//=============================================================================
// INSTITUTIONAL AI DECISION ENGINE
// MODULE 2.7 - PART A
//=============================================================================

institutionalScore = 0

institutionalScore += bullishBOS ? 10 : 0
institutionalScore += bullishCHOCH ? 8 : 0
institutionalScore += bullishLiquiditySweep ? 10 : 0
institutionalScore += bullishOB ? 8 : 0
institutionalScore += bullishFVG ? 6 : 0

institutionalScore += vixLow ? 5 : 0
institutionalScore -= vixHigh ? 5 : 0

finalAIScore = math.min(aiScore + institutionalScore, 100)
finalConfidence = finalAIScore
//=============================================================================
// INSTITUTIONAL DECISION
// MODULE 2.7 - PART B
//=============================================================================

institutionalDecision =
     finalAIScore >= 85 ? "STRONG BUY" :
     finalAIScore >= 70 ? "BUY" :
     finalAIScore >= 45 ? "WAIT" :
     finalAIScore >= 25 ? "SELL" :
     "STRONG SELL"

institutionalBuy = finalAIScore >= 70

institutionalSell = finalAIScore <= 25

institutionalWait = finalAIScore > 25 and finalAIScore < 70
//=============================================================================
// MODULE 2.7 - PART C
// DECISION CONFIDENCE
//=============================================================================

decisionReason =
     institutionalDecision == "STRONG BUY" ? "Institutional Bullish Confirmation" :
     institutionalDecision == "BUY" ? "Bullish Confirmation" :
     institutionalDecision == "WAIT" ? "Mixed Signals" :
     institutionalDecision == "SELL" ? "Bearish Confirmation" :
     "Institutional Bearish Confirmation"

decisionConfidence = str.tostring(finalConfidence) + "%"
//=============================================================================
// MODULE 2.7 - PART D
// DASHBOARD INTEGRATION
//=============================================================================

table.cell(instDashboard, 0, 6, "Final AI", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 6, str.tostring(finalAIScore), bgcolor=instDashBg, text_color=color.lime)

table.cell(instDashboard, 0, 7, "Decision", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 7, institutionalDecision, bgcolor=instDashBg, text_color=color.yellow)

table.cell(instDashboard, 0, 8, "Confidence", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 8, decisionConfidence, bgcolor=instDashBg, text_color=color.aqua)

table.cell(instDashboard, 0, 9, "Reason", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 9, decisionReason, bgcolor=instDashBg, text_color=color.orange)
//======================================================
// MODULE 2.8 - PART A
// MARKET STRUCTURE PANEL
//======================================================

table.cell(instDashboard, 0, 10, "BOS", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 10, bullishBOS ? "BULLISH" : bearishBOS ? "BEARISH" : "-", bgcolor=instDashBg, text_color=color.yellow)

table.cell(instDashboard, 0, 11, "CHOCH", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 11, bullishCHOCH ? "BULLISH" : bearishCHOCH ? "BEARISH" : "-", bgcolor=instDashBg, text_color=color.aqua)

table.cell(instDashboard, 0, 12, "Liquidity", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 12, bullishLiquiditySweep ? "BUY SIDE" : bearishLiquiditySweep ? "SELL SIDE" : "-", bgcolor=instDashBg, text_color=color.orange)

table.cell(instDashboard, 0, 13, "Order Block", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 13, bullishOB ? "BULLISH" : bearishOB ? "BEARISH" : "-", bgcolor=instDashBg, text_color=color.lime)

table.cell(instDashboard, 0, 14, "FVG", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 14, bullishFVG ? "BULLISH" : bearishFVG ? "BEARISH" : "-", bgcolor=instDashBg, text_color=color.fuchsia)
//======================================================
// MODULE 2.8 - PART B
// RISK PANEL
//======================================================

table.cell(instDashboard, 0, 15, "India VIX", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 15, str.tostring(vixValue, "#.##"), bgcolor=instDashBg, text_color=vixLow ? color.lime : vixHigh ? color.red : color.orange)

table.cell(instDashboard, 0, 16, "ADX", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 16, str.tostring(adxValue, "#.0"), bgcolor=instDashBg, text_color=strongTrend ? color.lime : color.orange)

table.cell(instDashboard, 0, 17, "ATR", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 17, str.tostring(atrValue, "#.##"), bgcolor=instDashBg, text_color=color.aqua)

table.cell(instDashboard, 0, 18, "Risk", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 18,
     lowVolatility ? "LOW" :
     highVolatility ? "HIGH" : "NORMAL",
     bgcolor=instDashBg,
     text_color=lowVolatility ? color.lime : highVolatility ? color.red : color.orange)
 //======================================================
// MODULE 2.8 - PART C
// INSTITUTIONAL STATUS PANEL
//======================================================

table.cell(instDashboard, 0, 19, "EMA", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 19,
     emaFast > emaSlow ? "BULLISH" : "BEARISH",
     bgcolor=instDashBg,
     text_color=emaFast > emaSlow ? color.lime : color.red)

table.cell(instDashboard, 0, 20, "VWAP", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 20,
     close > vwapValue ? "ABOVE" : "BELOW",
     bgcolor=instDashBg,
     text_color=close > vwapValue ? color.lime : color.red)

table.cell(instDashboard, 0, 21, "Volume", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 21,
     volumeSpike ? "SPIKE" : "NORMAL",
     bgcolor=instDashBg,
     text_color=volumeSpike ? color.lime : color.orange)

table.cell(instDashboard, 0, 22, "RVOL", bgcolor=instDashBg, text_color=instDashText)

table.cell(instDashboard, 1, 22,
     "--",
     bgcolor=instDashBg,
     text_color=color.gray)
     //====================================================
// MODULE 2.8 PART D
// PROFESSIONAL STATUS BANNER
//====================================================

bannerText =
     finalAIScore >= 85 ? "🟢 STRONG BUY" :
     finalAIScore >= 70 ? "🟢 BUY" :
     finalAIScore >= 50 ? "🟡 WAIT" :
     finalAIScore >= 30 ? "🟠 SELL" :
     "🔴 STRONG SELL"

bannerColor =
     finalAIScore >= 85 ? color.lime :
     finalAIScore >= 70 ? color.green :
     finalAIScore >= 50 ? color.yellow :
     finalAIScore >= 30 ? color.orange :
     color.red
 //====================================================
// MODULE 2.8 PART E
// STATUS BANNER
//====================================================

var label statusBanner = na

if barstate.islast
    label.delete(statusBanner)

    statusBanner := label.new(
         bar_index,
         high + atrValue * 2,
         bannerText + "\nAI Score : " + str.tostring(finalAIScore, "#"),
         style = label.style_label_down,
         color = bannerColor,
         textcolor = color.black,
         size = size.large)    

//====================================================
// MODULE 2.9 - PART A
// INSTITUTIONAL ALERT ENGINE
//====================================================

strongBuyAlert = finalAIScore >= 85

buySignalAlert = finalAIScore >= 70 and finalAIScore < 85

strongSellAlert = finalAIScore <= 15

sellSignalAlert = finalAIScore <= 30 and finalAIScore > 15

alertWait = finalAIScore > 30 and finalAIScore < 70

//====================================================
// MODULE 2.9 - PART B
// ALERT CONDITIONS
//====================================================

alertcondition(strongBuyAlert, title="GK Strong Buy", message="GK AI Trader Pro : STRONG BUY")

alertcondition(buySignalAlert, title="GK Buy", message="GK AI Trader Pro : BUY")

alertcondition(strongSellAlert, title="GK Strong Sell", message="GK AI Trader Pro : STRONG SELL")

alertcondition(sellSignalAlert, title="GK Sell", message="GK AI Trader Pro : SELL")

alertcondition(alertWait, title="GK Wait", message="GK AI Trader Pro : WAIT")

//====================================================
// MODULE 3.1
// INSTITUTIONAL ENTRY ENGINE
//====================================================

groupEntry = "🚀 Institutional Entry Engine"

enableEntryEngine = input.bool(true, "Enable Entry Engine", group=groupEntry)

// Buy Conditions
longEntry = enableEntryEngine and finalAIScore >= 70 and trendBullish and close > vwapValue

// Sell Conditions
shortEntry = enableEntryEngine and finalAIScore <= 30 and trendBearish and close < vwapValue

plotshape(
     longEntry,
     title="Institutional Buy",
     style=shape.triangleup,
     location=location.belowbar,
     color=color.lime,
     size=size.small,
     text="BUY"
)

plotshape(
     shortEntry,
     title="Institutional Sell",
     style=shape.triangledown,
     location=location.abovebar,
     color=color.red,
     size=size.small,
     text="SELL"
)

//====================================================
// MODULE 3.2
// ATR STOP LOSS ENGINE
//====================================================

groupATRStop = "🛡 ATR Stop"

enableATRStop = input.bool(
    true,
    "Enable ATR Stop",
    group = groupATRStop
)

longStopLoss = enableATRStop ? close - atrValue * atrMultiplier : na
shortStopLoss = enableATRStop ? close + atrValue * atrMultiplier : na

plot(longStopLoss,
     title="Long Stop",
     color=color.red,
     linewidth=2)

plot(shortStopLoss,
     title="Short Stop",
     color=color.green,
     linewidth=2)
     //======================================================
// MODULE 3.3
// TRAILING STOP ENGINE
//======================================================

groupTrail = "🔄 Trailing Stop"

// Master Switch
enableTrailing = input.bool(
    true,
    "Enable Trailing Stop",
    group = groupTrail
)

// Trailing Type
trailingType = input.string(
    "ATR",
    "Trailing Type",
    options = ["ATR", "Swing"],
    group = groupTrail
)

// ATR Multiplier
trailATRMultiplier = input.float(
    2.0,
    "ATR Trail Multiplier",
    minval = 0.5,
    step = 0.5,
    group = groupTrail
)

// Swing Lookback
swingLookback = input.int(
    5,
    "Swing Lookback",
    minval = 2,
    maxval = 50,
    group = groupTrail
)

// Break Even
enableBreakEven = input.bool(
    true,
    "Enable Break Even",
    group = groupTrail
)

breakEvenRR = input.float(
    1.0,
    "Break Even RR",
    minval = 0.5,
    step = 0.5,
    group = groupTrail
)
//======================================================
// MODULE 3.3 - PART 2
// BREAK EVEN ENGINE (INDICATOR)
//======================================================

longEntryPrice = longEntry ? close : na
shortEntryPrice = shortEntry ? close : na

breakEvenLongPrice = longEntry ? longEntryPrice : na
breakEvenShortPrice = shortEntry ? shortEntryPrice : na

plot(
    enableBreakEven ? breakEvenLongPrice : na,
    title="Break Even Long",
    color=color.blue,
    linewidth=2
)

plot(
    enableBreakEven ? breakEvenShortPrice : na,
    title="Break Even Short",
    color=color.purple,
    linewidth=2
)
//======================================================
// MODULE 3.3 - PART 3
// ATR TRAILING STOP ENGINE
//======================================================

// ATR Based Trailing Stop
atrTrailLong = enableTrailing and trailingType == "ATR" ? close - (atrValue * trailATRMultiplier) : na

atrTrailShort = enableTrailing and trailingType == "ATR" ? close + (atrValue * trailATRMultiplier) : na

// Plot ATR Trail
plot(
    atrTrailLong,
    title = "ATR Trail Long",
    color = color.orange,
    linewidth = 2
)

plot(
    atrTrailShort,
    title = "ATR Trail Short",
    color = color.yellow,
    linewidth = 2
)
//======================================================
// MODULE 3.3 - PART 4
// SWING TRAILING STOP ENGINE
//======================================================

// Swing Levels
swingLowTrail = ta.lowest(low, swingLookback)
swingHighTrail = ta.highest(high, swingLookback)

// Swing Trailing Stop
swingTrailLong = enableTrailing and trailingType == "Swing" ? swingLowTrail : na
swingTrailShort = enableTrailing and trailingType == "Swing" ? swingHighTrail : na

// Plot Swing Trail
plot(
    swingTrailLong,
    title = "Swing Trail Long",
    color = color.teal,
    linewidth = 2
)

plot(
    swingTrailShort,
    title = "Swing Trail Short",
    color = color.maroon,
    linewidth = 2
)
//======================================================
// MODULE 3.3 - PART 5
// FINAL TRAILING ENGINE
//======================================================

finalLongTrail = trailingType == "ATR" ? atrTrailLong : swingTrailLong
finalShortTrail = trailingType == "ATR" ? atrTrailShort : swingTrailShort

// Plot Final Trail
plot(
    finalLongTrail,
    title = "Final Long Trail",
    color = color.green,
    linewidth = 3
)

plot(
    finalShortTrail,
    title = "Final Short Trail",
    color = color.red,
    linewidth = 3
)
//======================================================
// MODULE 3.4
// DYNAMIC RISK : REWARD ENGINE
//======================================================

groupRR = "🎯 Risk : Reward"

enableRREngine = input.bool(true, "Enable RR Engine", group=groupRR)

rrTarget1 = input.float(1.0, "Target 1 (R)", step=0.5, group=groupRR)
rrTarget2 = input.float(2.0, "Target 2 (R)", step=0.5, group=groupRR)
rrTarget3 = input.float(3.0, "Target 3 (R)", step=0.5, group=groupRR)

// Risk Distance
longRiskPoints = math.abs(close - longStopLoss)
shortRiskPoints = math.abs(shortStopLoss - close)

//======================================================
// MODULE 3.4 - PART 2
// TARGET PRICE ENGINE
//======================================================

// Long Targets
longTarget1 = enableRREngine ? close + (longRiskPoints * rrTarget1) : na
longTarget2 = enableRREngine ? close + (longRiskPoints * rrTarget2) : na
longTarget3 = enableRREngine ? close + (longRiskPoints * rrTarget3) : na

// Short Targets
shortTarget1 = enableRREngine ? close - (shortRiskPoints * rrTarget1) : na
shortTarget2 = enableRREngine ? close - (shortRiskPoints * rrTarget2) : na
shortTarget3 = enableRREngine ? close - (shortRiskPoints * rrTarget3) : na

//======================================================
// MODULE 3.4 - PART 3
// TARGET PLOTS
//======================================================

plot(longTarget1, "Long T1", color=color.lime)
plot(longTarget2, "Long T2", color=color.green)
plot(longTarget3, "Long T3", color=color.teal)

plot(shortTarget1, "Short T1", color=color.orange)
plot(shortTarget2, "Short T2", color=color.red)
plot(shortTarget3, "Short T3", color=color.maroon)

//======================================================
// MODULE 3.5 - PART 1
// SMART TRADE MANAGEMENT
//======================================================


// Trade Status
tradeStatus =
     longEntry ? "LONG ACTIVE" :
     shortEntry ? "SHORT ACTIVE" :
     "NO TRADE"

// Trade Direction
tradeDirection =
     longEntry ? 1 :
     shortEntry ? -1 :
     0
  //======================================================
// TRADE ACTIVE STATE
//======================================================

var bool tradeActive = false
var bool longTradeActive = false
var bool shortTradeActive = false

if longEntry
    tradeActive := true
    longTradeActive := true
    shortTradeActive := false

if shortEntry
    tradeActive := true
    shortTradeActive := true
    longTradeActive := false   
    //======================================================
// MODULE 3.5 - PART 2
// T1 HIT DETECTION
//======================================================

var bool longT1Hit = false
var bool shortT1Hit = false

// Reset on new trade
if longEntry
    longT1Hit := false

if shortEntry
    shortT1Hit := false

// Detect T1 Hit
if longTradeActive and high >= longTarget1
    longT1Hit := true

if shortTradeActive and low <= shortTarget1
    shortT1Hit := true
    //======================================================
// MODULE 3.5 - PART 3
// T2 HIT DETECTION
//======================================================

var bool longT2Hit = false
var bool shortT2Hit = false

// Reset on new trade
if longEntry
    longT2Hit := false

if shortEntry
    shortT2Hit := false

// Detect T2 Hit
if longTradeActive and longT1Hit and high >= longTarget2
    longT2Hit := true

if shortTradeActive and shortT1Hit and low <= shortTarget2
    shortT2Hit := true
 //======================================================
// MODULE 3.5 - PART 4
// T3 HIT DETECTION
//======================================================

var bool longT3Hit = false
var bool shortT3Hit = false

// Reset on new trade
if longEntry
    longT3Hit := false

if shortEntry
    shortT3Hit := false

// Detect T3 Hit
if longTradeActive and longT2Hit and high >= longTarget3
    longT3Hit := true

if shortTradeActive and shortT2Hit and low <= shortTarget3
    shortT3Hit := true
  //======================================================
// MODULE 3.5 - PART 5
// BREAK-EVEN STATUS
//======================================================

breakEvenActive = (longTradeActive and longT1Hit) or (shortTradeActive and shortT1Hit)

breakEvenStatus = breakEvenActive ? "ACTIVE" : "PENDING"
//======================================================
// MODULE 3.5 - PART 6
// TRAILING STATUS
//======================================================

trailingActive = (longTradeActive and longT2Hit) or (shortTradeActive and shortT2Hit)

trailingStatus = trailingActive ? "ACTIVE" : "OFF"
 //======================================================
// MODULE 3.5 - PART 7
// TRADE CLOSED STATUS
//======================================================

tradeClosed = (longTradeActive and longT3Hit) or (shortTradeActive and shortT3Hit)

tradeResult = tradeClosed ? "TARGET ACHIEVED" : "RUNNING"
//======================================================
// MODULE 3.6 - PART 1
// PROFESSIONAL LABELS
//======================================================

// Long Active Label
plotshape(
     longTradeActive,
     title="Long Active",
     style=shape.labelup,
     location=location.belowbar,
     color=color.lime,
     text="LONG",
     textcolor=color.white,
     size=size.tiny)

// Short Active Label
plotshape(
     shortTradeActive,
     title="Short Active",
     style=shape.labeldown,
     location=location.abovebar,
     color=color.red,
     text="SHORT",
     textcolor=color.white,
     size=size.tiny)
     //======================================================
// MODULE 3.6 - PART 2
// TARGET HIT LABELS
//======================================================

// T1 Labels
plotshape(
     longT1Hit and not longT1Hit[1],
     title="Long T1",
     style=shape.labelup,
     location=location.abovebar,
     color=color.green,
     text="T1",
     textcolor=color.white,
     size=size.tiny)

plotshape(
     shortT1Hit and not shortT1Hit[1],
     title="Short T1",
     style=shape.labeldown,
     location=location.belowbar,
     color=color.red,
     text="T1",
     textcolor=color.white,
     size=size.tiny)
     //======================================================
// MODULE 3.6 - PART 3
// T2 & T3 LABELS
//======================================================

// Long T2
plotshape(
     longT2Hit and not longT2Hit[1],
     title="Long T2",
     style=shape.labelup,
     location=location.abovebar,
     color=color.blue,
     text="T2",
     textcolor=color.white,
     size=size.tiny)

// Short T2
plotshape(
     shortT2Hit and not shortT2Hit[1],
     title="Short T2",
     style=shape.labeldown,
     location=location.belowbar,
     color=color.orange,
     text="T2",
     textcolor=color.white,
     size=size.tiny)

// Long T3
plotshape(
     longT3Hit and not longT3Hit[1],
     title="Long T3",
     style=shape.labelup,
     location=location.abovebar,
     color=color.purple,
     text="T3",
     textcolor=color.white,
     size=size.small)

// Short T3
plotshape(
     shortT3Hit and not shortT3Hit[1],
     title="Short T3",
     style=shape.labeldown,
     location=location.belowbar,
     color=color.maroon,
     text="T3",
     textcolor=color.white,
     size=size.small)
     //======================================================
// MODULE 3.6 - PART 4
// BREAK-EVEN LABEL
//======================================================

plotshape(
     breakEvenActive and not breakEvenActive[1],
     title = "Break Even Active",
     style = shape.diamond,
     location = location.abovebar,
     color = color.aqua,
     text = "BE",
     textcolor = color.black,
     size = size.small)
     //======================================================
// MODULE 3.6 - PART 5
// TRAILING STOP LABEL
//======================================================

plotshape(
     trailingActive and not trailingActive[1],
     title = "Trailing Active",
     style = shape.circle,
     location = location.belowbar,
     color = color.orange,
     text = "TRAIL",
     textcolor = color.white,
     size = size.small)
     //======================================================
// MODULE 3.6 - PART 6
// TRADE CLOSED LABEL
//======================================================

plotshape(
     tradeClosed and not tradeClosed[1],
     title = "Trade Closed",
     style = shape.xcross,
     location = location.abovebar,
     color = color.red,
     text = "EXIT",
     textcolor = color.white,
     size = size.small)