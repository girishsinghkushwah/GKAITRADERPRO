//@version=6

//=============================================================================
// GK AI TRADER PRO
// Institutional Decision Engine
// Version : 0.1.0
// Author  : Girish Kushwah + ChatGPT
//=============================================================================

indicator(
     title = "GK AI Trader Pro",
     shorttitle = "GK AI",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500
)

//=============================================================================
// PROJECT INFORMATION
//=============================================================================

var string PROJECT_NAME    = "GK AI Trader Pro"
var string VERSION         = "0.1.0"
var string BUILD_DATE      = "2026-07-07"

var string DEVELOPER       = "Girish Kushwah"
var string ENGINE          = "Institutional Decision Engine"

var bool INITIALIZED = true
plot(close, title="Foundation")
//=============================================================================
// INPUT SETTINGS
//=============================================================================

// General
groupGeneral = "⚙️ General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
showSignals   = input.bool(true, "Show Buy/Sell Signals", group = groupGeneral)
enableAlerts  = input.bool(true, "Enable Alerts", group = groupGeneral)

// Market
groupMarket = "📈 Market"

marketType = input.string(
     "NIFTY",
     "Market",
     options = ["NIFTY", "SENSEX", "BANKNIFTY"],
     group = groupMarket
)

// Trading Style
groupStyle = "🎯 Trading Style"

tradingStyle = input.string(
     "Intraday",
     "Style",
     options = ["Scalping", "Intraday", "Swing"],
     group = groupStyle
)
//=============================================================================
// THEME ENGINE
//=============================================================================

groupTheme = "🎨 Theme"

theme = input.string(
     "Institutional Dark",
     "Theme",
     options = [
         "Institutional Dark",
         "Light",
         "Classic"
     ],
     group = groupTheme
)

// Color Palette
bullColor    = color.lime
bearColor    = color.red
neutralColor = color.orange

dashboardBg  = color.rgb(25, 25, 30)
dashboardTxt = color.white

buyColor     = color.lime
sellColor    = color.red
warningColor = color.yellow
//=============================================================================
// UTILITY ENGINE
//=============================================================================

// Candle Information
isBullish() =>
    close > open

isBearish() =>
    close < open

candleBody() =>
    math.abs(close - open)

upperWick() =>
    high - math.max(open, close)

lowerWick() =>
    math.min(open, close) - low

// Trend Helpers
isAboveVWAP(vwapValue) =>
    close > vwapValue

isBelowVWAP(vwapValue) =>
    close < vwapValue

// Price Helpers
priceChange() =>
    close - close[1]

priceChangePercent() =>
    ((close - close[1]) / close[1]) * 100
    //=============================================================================
// DASHBOARD FOUNDATION
//=============================================================================

groupDashboard = "📊 Dashboard"

dashboardPosition = input.string(
     "Top Right",
     "Position",
     options = [
          "Top Right",
          "Top Left",
          "Bottom Right",
          "Bottom Left"
     ],
     group = groupDashboard
)

dashboardSize = input.string(
     "Normal",
     "Size",
     options = [
          "Small",
          "Normal",
          "Large"
     ],
     group = groupDashboard
)

showVersion = input.bool(
     true,
     "Show Version",
     group = groupDashboard
)
//=============================================================================
// EMA ENGINE
//=============================================================================

groupEMA = "📈 EMA Engine"

enableEMA = input.bool(true, "Enable EMA Engine", group = groupEMA)

emaFastLength = input.int(8, "Fast EMA", minval = 1, group = groupEMA)
emaSlowLength = input.int(14, "Slow EMA", minval = 1, group = groupEMA)

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)

// Trend State
trendBullish = emaFast > emaSlow
trendBearish = emaFast < emaSlow
trendNeutral = emaFast == emaSlow

// EMA Distance
emaDistance = math.abs(emaFast - emaSlow)

// EMA Slope
emaFastSlope = emaFast - emaFast[1]
emaSlowSlope = emaSlow - emaSlow[1]

// Plots
plot(enableEMA ? emaFast : na,
     title = "EMA Fast",
     color = bullColor,
     linewidth = 2)

plot(enableEMA ? emaSlow : na,
     title = "EMA Slow",
     color = bearColor,
     linewidth = 2)
     //=============================================================================
// VWAP ENGINE
//=============================================================================

groupVWAP = "📊 VWAP Engine"

enableVWAP = input.bool(true, "Enable VWAP Engine", group = groupVWAP)
showVWAP   = input.bool(true, "Show VWAP", group = groupVWAP)

// VWAP
vwapValue = ta.vwap(close)

// Market State
priceAboveVWAP = close > vwapValue
priceBelowVWAP = close < vwapValue
priceOnVWAP    = close == vwapValue

// Distance
vwapDistance = math.abs(close - vwapValue)

// Plot
plot(
     enableVWAP and showVWAP ? vwapValue : na,
     title = "VWAP",
     color = color.aqua,
     linewidth = 2
)
//=============================================================================
// VOLUME ENGINE
//=============================================================================

groupVolume = "📊 Volume Engine"

enableVolume = input.bool(true, "Enable Volume Engine", group = groupVolume)

volumeLength = input.int(
     20,
     "Average Volume Length",
     minval = 1,
     group = groupVolume
)

rvolThreshold = input.float(
     1.5,
     "RVOL Threshold",
     step = 0.1,
     group = groupVolume
)

// Average Volume
avgVolume = ta.sma(volume, volumeLength)

// Relative Volume
rvol = avgVolume > 0 ? volume / avgVolume : 0

// Volume Conditions
highVolume = volume > avgVolume
volumeSpike = rvol >= rvolThreshold

// Plot Average Volume (Hidden)
plot(
     enableVolume ? avgVolume : na,
     title = "Average Volume",
     display = display.none
)
//=============================================================================
// RSI ENGINE
//=============================================================================

groupRSI = "📈 RSI Engine"

enableRSI = input.bool(true, "Enable RSI Engine", group = groupRSI)

rsiLength = input.int(
    14,
    "RSI Length",
    minval = 2,
    group = groupRSI
)

rsiOB = input.int(
    70,
    "Overbought",
    minval = 50,
    maxval = 100,
    group = groupRSI
)

rsiOS = input.int(
    30,
    "Oversold",
    minval = 0,
    maxval = 50,
    group = groupRSI
)

// RSI Calculation
rsiValue = ta.rsi(close, rsiLength)

// Momentum States
rsiStrongBull = rsiValue >= 70
rsiBull       = rsiValue > 55 and rsiValue < 70
rsiNeutral    = rsiValue >= 45 and rsiValue <= 55
rsiBear       = rsiValue < 45 and rsiValue > 30
rsiStrongBear = rsiValue <= 30

// Hidden Plot (Future AI Use)
plot(
    enableRSI ? rsiValue : na,
    title = "RSI",
    display = display.none
)
//=============================================================================
// MACD ENGINE
//=============================================================================

groupMACD = "📉 MACD Engine"

enableMACD = input.bool(true, "Enable MACD Engine", group = groupMACD)

macdFast = input.int(12, "Fast Length", group = groupMACD)
macdSlow = input.int(26, "Slow Length", group = groupMACD)
macdSignal = input.int(9, "Signal Length", group = groupMACD)

// Calculation
[macdLine, signalLine, histogram] = ta.macd(close, macdFast, macdSlow, macdSignal)

// States
macdBullish = macdLine > signalLine
macdBearish = macdLine < signalLine

macdStrongBull = histogram > 0 and histogram > histogram[1]
macdStrongBear = histogram < 0 and histogram < histogram[1]

// Hidden Plot
plot(
    enableMACD ? macdLine : na,
    title = "MACD",
    display = display.none
)