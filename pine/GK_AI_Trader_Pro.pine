//@version=6

//=============================================================================
// GK AI TRADER PRO
// Institutional Decision Engine
// Version : 0.1.0
// Author  : Girish Kushwah + ChatGPT
//=============================================================================

indicator(
     title = "GK AI Trader Pro",
     shorttitle = "GK AI",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500
)

//=============================================================================
// PROJECT INFORMATION
//=============================================================================

var string PROJECT_NAME    = "GK AI Trader Pro"
var string VERSION         = "0.1.0"
var string BUILD_DATE      = "2026-07-07"

var string DEVELOPER       = "Girish Kushwah"
var string ENGINE          = "Institutional Decision Engine"

var bool INITIALIZED = true
plot(close, title="Foundation")
//=============================================================================
// INPUT SETTINGS
//=============================================================================

// General
groupGeneral = "⚙️ General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
showSignals   = input.bool(true, "Show Buy/Sell Signals", group = groupGeneral)
enableAlerts  = input.bool(true, "Enable Alerts", group = groupGeneral)

// Market
groupMarket = "📈 Market"

marketType = input.string(
     "NIFTY",
     "Market",
     options = ["NIFTY", "SENSEX", "BANKNIFTY"],
     group = groupMarket
)

// Trading Style
groupStyle = "🎯 Trading Style"

tradingStyle = input.string(
     "Intraday",
     "Style",
     options = ["Scalping", "Intraday", "Swing"],
     group = groupStyle
)
//=============================================================================
// THEME ENGINE
//=============================================================================

groupTheme = "🎨 Theme"

theme = input.string(
     "Institutional Dark",
     "Theme",
     options = [
         "Institutional Dark",
         "Light",
         "Classic"
     ],
     group = groupTheme
)

// Color Palette
bullColor    = color.lime
bearColor    = color.red
neutralColor = color.orange

dashboardBg  = color.rgb(25, 25, 30)
dashboardTxt = color.white

buyColor     = color.lime
sellColor    = color.red
warningColor = color.yellow
//=============================================================================
// UTILITY ENGINE
//=============================================================================

// Candle Information
isBullish() =>
    close > open

isBearish() =>
    close < open

candleBody() =>
    math.abs(close - open)

upperWick() =>
    high - math.max(open, close)

lowerWick() =>
    math.min(open, close) - low

// Trend Helpers
isAboveVWAP(vwapValue) =>
    close > vwapValue

isBelowVWAP(vwapValue) =>
    close < vwapValue

// Price Helpers
priceChange() =>
    close - close[1]

priceChangePercent() =>
    ((close - close[1]) / close[1]) * 100
    //=============================================================================
// DASHBOARD FOUNDATION
//=============================================================================

groupDashboard = "📊 Dashboard"

dashboardPosition = input.string(
     "Top Right",
     "Position",
     options = [
          "Top Right",
          "Top Left",
          "Bottom Right",
          "Bottom Left"
     ],
     group = groupDashboard
)

dashboardSize = input.string(
     "Normal",
     "Size",
     options = [
          "Small",
          "Normal",
          "Large"
     ],
     group = groupDashboard
)

showVersion = input.bool(
     true,
     "Show Version",
     group = groupDashboard
)
//=============================================================================
// EMA ENGINE
//=============================================================================

groupEMA = "📈 EMA Engine"

enableEMA = input.bool(true, "Enable EMA Engine", group = groupEMA)

emaFastLength = input.int(8, "Fast EMA", minval = 1, group = groupEMA)
emaSlowLength = input.int(14, "Slow EMA", minval = 1, group = groupEMA)

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)

// Trend State
trendBullish = emaFast > emaSlow
trendBearish = emaFast < emaSlow
trendNeutral = emaFast == emaSlow

// EMA Distance
emaDistance = math.abs(emaFast - emaSlow)

// EMA Slope
emaFastSlope = emaFast - emaFast[1]
emaSlowSlope = emaSlow - emaSlow[1]

// Plots
plot(enableEMA ? emaFast : na,
     title = "EMA Fast",
     color = bullColor,
     linewidth = 2)

plot(enableEMA ? emaSlow : na,
     title = "EMA Slow",
     color = bearColor,
     linewidth = 2)
     //=============================================================================
// VWAP ENGINE
//=============================================================================

groupVWAP = "📊 VWAP Engine"

enableVWAP = input.bool(true, "Enable VWAP Engine", group = groupVWAP)
showVWAP   = input.bool(true, "Show VWAP", group = groupVWAP)

// VWAP
vwapValue = ta.vwap(close)

// Market State
priceAboveVWAP = close > vwapValue
priceBelowVWAP = close < vwapValue
priceOnVWAP    = close == vwapValue

// Distance
vwapDistance = math.abs(close - vwapValue)

// Plot
plot(
     enableVWAP and showVWAP ? vwapValue : na,
     title = "VWAP",
     color = color.aqua,
     linewidth = 2
)
//=============================================================================
// VOLUME ENGINE
//=============================================================================

groupVolume = "📊 Volume Engine"

enableVolume = input.bool(true, "Enable Volume Engine", group = groupVolume)

volumeLength = input.int(
     20,
     "Average Volume Length",
     minval = 1,
     group = groupVolume
)

rvolThreshold = input.float(
     1.5,
     "RVOL Threshold",
     step = 0.1,
     group = groupVolume
)

// Average Volume
avgVolume = ta.sma(volume, volumeLength)

// Relative Volume
rvol = avgVolume > 0 ? volume / avgVolume : 0

// Volume Conditions
highVolume = volume > avgVolume
volumeSpike = rvol >= rvolThreshold

// Plot Average Volume (Hidden)
plot(
     enableVolume ? avgVolume : na,
     title = "Average Volume",
     display = display.none
)
//=============================================================================
// RSI ENGINE
//=============================================================================

groupRSI = "📈 RSI Engine"

enableRSI = input.bool(true, "Enable RSI Engine", group = groupRSI)

rsiLength = input.int(
    14,
    "RSI Length",
    minval = 2,
    group = groupRSI
)

rsiOB = input.int(
    70,
    "Overbought",
    minval = 50,
    maxval = 100,
    group = groupRSI
)

rsiOS = input.int(
    30,
    "Oversold",
    minval = 0,
    maxval = 50,
    group = groupRSI
)

// RSI Calculation
rsiValue = ta.rsi(close, rsiLength)

// Momentum States
rsiStrongBull = rsiValue >= 70
rsiBull       = rsiValue > 55 and rsiValue < 70
rsiNeutral    = rsiValue >= 45 and rsiValue <= 55
rsiBear       = rsiValue < 45 and rsiValue > 30
rsiStrongBear = rsiValue <= 30

// Hidden Plot (Future AI Use)
plot(
    enableRSI ? rsiValue : na,
    title = "RSI",
    display = display.none
)
//=============================================================================
// MACD ENGINE
//=============================================================================

groupMACD = "📉 MACD Engine"

enableMACD = input.bool(true, "Enable MACD Engine", group = groupMACD)

macdFast = input.int(12, "Fast Length", group = groupMACD)
macdSlow = input.int(26, "Slow Length", group = groupMACD)
macdSignal = input.int(9, "Signal Length", group = groupMACD)

// Calculation
[macdLine, signalLine, histogram] = ta.macd(close, macdFast, macdSlow, macdSignal)

// States
macdBullish = macdLine > signalLine
macdBearish = macdLine < signalLine

macdStrongBull = histogram > 0 and histogram > histogram[1]
macdStrongBear = histogram < 0 and histogram < histogram[1]

// Hidden Plot
plot(
    enableMACD ? macdLine : na,
    title = "MACD",
    display = display.none
)
//=============================================================================
// ADX ENGINE
//=============================================================================

groupADX = "📊 ADX Engine"

enableADX = input.bool(true, "Enable ADX Engine", group = groupADX)

adxLength = input.int(
    14,
    "ADX Length",
    minval = 2,
    group = groupADX
)

adxStrongLevel = input.int(
    25,
    "Strong Trend Level",
    minval = 10,
    maxval = 50,
    group = groupADX
)

// ADX Calculation
[diplus, diminus, adxValue] = ta.dmi(adxLength, adxLength)

// Trend Strength
strongTrend = adxValue >= adxStrongLevel
weakTrend   = adxValue < adxStrongLevel

bullTrend = diplus > diminus
bearTrend = diminus > diplus

// Hidden Plot
plot(
    enableADX ? adxValue : na,
    title = "ADX",
    display = display.none
)
//=============================================================================
// ATR ENGINE
//=============================================================================

groupATR = "📏 ATR Engine"

enableATR = input.bool(true, "Enable ATR Engine", group = groupATR)

atrLength = input.int(
    14,
    "ATR Length",
    minval = 1,
    group = groupATR
)

atrMultiplier = input.float(
    2.0,
    "ATR Multiplier",
    minval = 0.5,
    step = 0.5,
    group = groupATR
)

// ATR Calculation
atrValue = ta.atr(atrLength)

// Volatility State
highVolatility = atrValue > ta.sma(atrValue, atrLength)
lowVolatility  = atrValue <= ta.sma(atrValue, atrLength)

// Suggested Stop Loss Distance
atrSL = atrValue * atrMultiplier

// Hidden Plot
plot(
    enableATR ? atrValue : na,
    title = "ATR",
    display = display.none
)
//=============================================================================
// AI SCORE ENGINE
//=============================================================================

groupAI = "🧠 AI Score"

showAIScore = input.bool(true, "Enable AI Score", group = groupAI)

//----------------------------------------------------
// Trend Score
//----------------------------------------------------

trendScore = 0

trendScore += trendBullish ? 20 : 0
trendScore += priceAboveVWAP ? 20 : 0

//----------------------------------------------------
// Momentum Score
//----------------------------------------------------

momentumScore = 0

momentumScore += rsiBull or rsiStrongBull ? 15 : 0
momentumScore += macdBullish ? 15 : 0

//----------------------------------------------------
// Strength Score
//----------------------------------------------------

strengthScore = 0

strengthScore += strongTrend ? 10 : 0
strengthScore += volumeSpike ? 10 : 0

//----------------------------------------------------
// Risk Score
//----------------------------------------------------

riskScore = 0

riskScore += lowVolatility ? 10 : 0

//----------------------------------------------------
// Final Score
//----------------------------------------------------

aiScore = trendScore + momentumScore + strengthScore + riskScore

confidence = aiScore
//=============================================================================
// CORE STATE ENGINE
//=============================================================================

groupCore = "🧠 Core State Engine"

enableCore = input.bool(
    true,
    "Enable Core State Engine",
    group = groupCore
)

//======================================================
// STATE VALUES
//======================================================

// Trend
trendState = trendBullish ? 1 : trendBearish ? -1 : 0

// Momentum
momentumState =
     (rsiBull or rsiStrongBull) and macdBullish ? 1 :
     (rsiBear or rsiStrongBear) and macdBearish ? -1 : 0

// Strength
strengthState = strongTrend ? 1 : 0

// Volume
volumeState = volumeSpike ? 1 : 0

// Risk
riskState = lowVolatility ? 1 : 0

//======================================================
// MASTER STATE
//======================================================

marketState =
     trendState +
     momentumState +
     strengthState +
     volumeState +
     riskState
     //=============================================================================
// DECISION ENGINE
//=============================================================================

groupDecision = "🎯 Decision Engine"

enableDecision = input.bool(
    true,
    "Enable Decision Engine",
    group = groupDecision
)

// Decision Score
buyCall =
     aiScore >= 80 and
     trendState == 1 and
     momentumState == 1

buyPut =
     aiScore >= 80 and
     trendState == -1 and
     momentumState == -1

waitTrade =
     aiScore >= 60 and aiScore < 80

noTrade =
     aiScore < 60

// Decision Text
decision =
     buyCall ? "BUY CALL" :
     buyPut ? "BUY PUT" :
     waitTrade ? "WAIT" :
     "NO TRADE"
     //=============================================================================
// AI DASHBOARD
//=============================================================================

groupDashboardUI = "🖥️ AI Dashboard"

showAIDashboard = input.bool(true, "Show AI Dashboard", group = groupDashboardUI)

var table aiDashboard = table.new(position.top_right, 2, 6, border_width = 1)

if barstate.islast and showAIDashboard
    table.cell(aiDashboard, 0, 0, "GK AI Trader", bgcolor=color.blue, text_color=color.white)
    table.cell(aiDashboard, 1, 0, "v0.1.16", bgcolor=color.blue, text_color=color.white)

    table.cell(aiDashboard, 0, 1, "AI Score")
    table.cell(aiDashboard, 1, 1, str.tostring(aiScore))

    table.cell(aiDashboard, 0, 2, "Decision")
    table.cell(aiDashboard, 1, 2, decision)

    table.cell(aiDashboard, 0, 3, "Trend")
    table.cell(aiDashboard, 1, 3, trendState == 1 ? "Bullish" : trendState == -1 ? "Bearish" : "Neutral")

    table.cell(aiDashboard, 0, 4, "Momentum")
    table.cell(aiDashboard, 1, 4, momentumState == 1 ? "Bullish" : momentumState == -1 ? "Bearish" : "Neutral")

    table.cell(aiDashboard, 0, 5, "Volume")
    table.cell(aiDashboard, 1, 5, volumeSpike ? "High" : "Normal")
    //=============================================================================
// ALERT ENGINE
//=============================================================================

groupAlerts = "🔔 Alert Engine"

enableAIAlerts = input.bool(true, "Enable Alerts", group = groupAlerts)

//----------------------------------------------------
// Alert Conditions
//----------------------------------------------------

buyCallAlert = enableAIAlerts and buyCall
buyPutAlert  = enableAIAlerts and buyPut
waitAlert    = enableAIAlerts and waitTrade

//----------------------------------------------------
// TradingView Alerts
//----------------------------------------------------

alertcondition(
    buyCallAlert,
    title = "BUY CALL",
    message = "GK AI Trader Pro : BUY CALL"
)

alertcondition(
    buyPutAlert,
    title = "BUY PUT",
    message = "GK AI Trader Pro : BUY PUT"
)

alertcondition(
    waitAlert,
    title = "WAIT",
    message = "GK AI Trader Pro : WAIT"
)
//=============================================================================
// TRADE MANAGEMENT ENGINE
//=============================================================================

groupTrade = "💼 Trade Management"

enableTradeManagement = input.bool(
    true,
    "Enable Trade Management",
    group = groupTrade
)

//----------------------------------------------------
// Entry
//----------------------------------------------------

entryPrice = close

//----------------------------------------------------
// Stop Loss
//----------------------------------------------------

longSL = low - atrValue
shortSL = high + atrValue

//----------------------------------------------------
// Risk Reward
//----------------------------------------------------

riskReward = input.float(
    2.0,
    "Risk Reward",
    step = 0.5,
    group = groupTrade
)

//----------------------------------------------------
// Targets
//----------------------------------------------------

longTarget = entryPrice + (entryPrice - longSL) * riskReward

shortTarget = entryPrice - (shortSL - entryPrice) * riskReward
//=============================================================================
// RISK ENGINE
//=============================================================================

groupRisk = "⚠️ Risk Engine"

enableRiskEngine = input.bool(
    true,
    "Enable Risk Engine",
    group = groupRisk
)

//----------------------------------------------------
// Maximum Risk (%)
//----------------------------------------------------

maxRiskPercent = input.float(
    1.0,
    "Maximum Risk %",
    step = 0.25,
    group = groupRisk
)

//----------------------------------------------------
// Risk Calculation
//----------------------------------------------------

tradeRisk = math.abs(entryPrice - longSL)

riskAllowed = tradeRisk > 0

riskStateEngine = enableRiskEngine and riskAllowed ? 1 : 0
//=============================================================================
// SESSION ENGINE
//=============================================================================

groupSession = "🕒 Session Engine"

enableSessionEngine = input.bool(
    true,
    "Enable Session Filter",
    group = groupSession
)

tradeSession = input.session(
    "0915-1530",
    "Trading Session",
    group = groupSession
)

sessionActive = not na(time(timeframe.period, tradeSession))

allowTrading = enableSessionEngine ? sessionActive : true
//=============================================================================
// INDIA VIX ENGINE
// MODULE 1.21
//=============================================================================

groupVIX = "📉 India VIX"

enableVIX = input.bool(true, "Enable India VIX", group = groupVIX)

vixSymbol = input.symbol("NSE:INDIAVIX", "India VIX Symbol", group = groupVIX)

vixValue = request.security(vixSymbol, timeframe.period, close)
vixPrevious = request.security(vixSymbol, timeframe.period, close[1])

vixRising = vixValue > vixPrevious
vixFalling = vixValue < vixPrevious

vixHigh = vixValue >= 20
vixMedium = vixValue >= 15 and vixValue < 20
vixLow = vixValue < 15
//=============================================================================
// INSTITUTIONAL DASHBOARD
// MODULE 2.1 - PART A
//=============================================================================

groupInstDash = "🏦 Institutional Dashboard"

showInstDash = input.bool(true, "Show Institutional Dashboard", group=groupInstDash)

instDashBg = input.color(color.new(color.black, 10), "Dashboard Background", group=groupInstDash)

instDashText = input.color(color.white, "Dashboard Text", group=groupInstDash)

var table instDashboard = table.new(position.top_right, 2, 15, border_width=1)
if barstate.islast and showInstDash
    table.clear(instDashboard, 0, 0)

    table.cell(instDashboard, 0, 0, "GK AI TRADER PRO", bgcolor=instDashBg, text_color=color.yellow)
    table.cell(instDashboard, 1, 0, "v0.2.1", bgcolor=instDashBg, text_color=color.aqua)
table.cell(instDashboard, 0, 1, "AI Score", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 1, str.tostring(aiScore), bgcolor=instDashBg, text_color=color.lime)

table.cell(instDashboard, 0, 2, "Decision", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 2, decision, bgcolor=instDashBg, text_color=color.yellow)

table.cell(instDashboard, 0, 3, "Trend", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 3, trendState == 1 ? "Bullish" : trendState == -1 ? "Bearish" : "Neutral", bgcolor=instDashBg, text_color=color.aqua)

table.cell(instDashboard, 0, 4, "Momentum", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 4, momentumState == 1 ? "Bullish" : momentumState == -1 ? "Bearish" : "Neutral", bgcolor=instDashBg, text_color=color.orange)

table.cell(instDashboard, 0, 5, "Session", bgcolor=instDashBg, text_color=instDashText)
table.cell(instDashboard, 1, 5, allowTrading ? "ACTIVE" : "CLOSED", bgcolor=instDashBg, text_color=allowTrading ? color.lime : color.red)
//=============================================================================
// BOS ENGINE
// MODULE 2.2
//=============================================================================

groupBOS = "🏗️ BOS Engine"

enableBOS = input.bool(true, "Enable BOS", group=groupBOS)

bosSwingLength = input.int(5, "Swing Length", minval=2, group=groupBOS)

// Swing High / Low
swingHigh = ta.pivothigh(high, bosSwingLength, bosSwingLength)
swingLow  = ta.pivotlow(low, bosSwingLength, bosSwingLength)

// Last Confirmed Swing Levels
lastSwingHigh = ta.valuewhen(not na(swingHigh), swingHigh, 0)
lastSwingLow  = ta.valuewhen(not na(swingLow), swingLow, 0)

// BOS Conditions
bullishBOS = enableBOS and not na(lastSwingHigh) and close > lastSwingHigh
bearishBOS = enableBOS and not na(lastSwingLow) and close < lastSwingLow
//=============================================================================
// CHOCH ENGINE
// MODULE 2.3
//=============================================================================

groupCHOCH = "🔄 CHOCH Engine"

enableCHOCH = input.bool(true, "Enable CHOCH", group = groupCHOCH)

// CHOCH Conditions
bullishCHOCH = enableCHOCH and bearishBOS[1] and bullishBOS

bearishCHOCH = enableCHOCH and bullishBOS[1] and bearishBOS
//=============================================================================
// LIQUIDITY SWEEP ENGINE
// MODULE 2.4
//=============================================================================

groupLiquidity = "💧 Liquidity Sweep"

enableLiquidity = input.bool(true, "Enable Liquidity Sweep", group = groupLiquidity)

lookbackLiquidity = input.int(20, "Liquidity Lookback", minval = 5, group = groupLiquidity)

highestLiquidity = ta.highest(high, lookbackLiquidity)
lowestLiquidity = ta.lowest(low, lookbackLiquidity)

bullishLiquiditySweep = enableLiquidity and high > highestLiquidity[1] and close < highestLiquidity[1]

bearishLiquiditySweep = enableLiquidity and low < lowestLiquidity[1] and close > lowestLiquidity[1]